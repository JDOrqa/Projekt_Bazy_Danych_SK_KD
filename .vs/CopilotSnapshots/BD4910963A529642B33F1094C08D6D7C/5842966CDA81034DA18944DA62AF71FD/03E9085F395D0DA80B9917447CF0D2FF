import { useEffect, useState } from 'react';
import { Link } from 'react-router-dom';
import api from '../api';

export default function LowiskaList() {
  const [lowiska, setLowiska] = useState([]);

  useEffect(() => {
    api.get('/lowiska').then(res => setLowiska(res.data));
  }, []);

  return (
    <div className="p-6">
      <div className="flex justify-between items-center mb-4">
        <h1 className="text-2xl font-bold">Łowiska</h1>
        <Link 
          to="/lowiska/dodaj" 
          className="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700"
        >
          + Dodaj łowisko
        </Link>
      </div>

      <ul className="space-y-2">
        {lowiska.map(l => (
  <li key={l.id} className="border p-4 rounded">
    <strong>{l.nazwa}</strong> – typ: {l.typ || 'brak'} – pow. {l.powierzchnia_ha} ha, głęb. max {l.glebokosc_max} m
    {l.opis && <p className="text-gray-600 text-sm mt-1">{l.opis}</p>}
  </li>
))}
      </ul>
    </div>
  );
}