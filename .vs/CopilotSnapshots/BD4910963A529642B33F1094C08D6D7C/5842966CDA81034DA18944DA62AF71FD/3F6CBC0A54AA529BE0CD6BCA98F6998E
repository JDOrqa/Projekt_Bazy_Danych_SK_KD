import { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import toast from 'react-hot-toast';
import api from '../api';
import MapDrawer from '../components/MapDrawer';

export default function AddLowisko() {
  const [form, setForm] = useState({
    nazwa: '',
    typ: '',
    granice: '',
    powierzchnia_ha: '',
    glebokosc_max: '',
    opis: ''
  });
  const [graniceWKT, setGraniceWKT] = useState(null); // <--- Nowy stan na granice
  const [loading, setLoading] = useState(false);
  const navigate = useNavigate();

  const handleChange = (e) => {
    setForm({ ...form, [e.target.name]: e.target.value });
  };
   const handlePolygonChange = (wkt) => {
    setGraniceWKT(wkt);
  };

    const handleSubmit = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      const payload = {
        nazwa: form.nazwa,
        typ: form.typ || null,
        powierzchnia_ha: form.powierzchnia_ha ? parseFloat(form.powierzchnia_ha) : null,
        glebokosc_max: form.glebokosc_max ? parseFloat(form.glebokosc_max) : null,
        opis: form.opis || null,
        granice: graniceWKT // <--- Wysyłamy WKT z mapy
      };
      await api.post('/lowiska', payload);
      toast.success('Łowisko dodane pomyślnie!');
      navigate('/lowiska');
    } catch (err) {
      console.error(err);
      toast.error(err.response?.data?.detail || 'Błąd dodawania łowiska');
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="max-w-2xl mx-auto p-6">
      <h1 className="text-2xl font-bold mb-6">Dodaj nowe łowisko</h1>
      <form onSubmit={handleSubmit} className="space-y-4">
        <div>
          <label className="block text-sm font-medium mb-1">Nazwa *</label>
          <input
            type="text"
            name="nazwa"
            required
            value={form.nazwa}
            onChange={handleChange}
            className="w-full border rounded px-3 py-2"
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Typ (jezioro, rzeka, staw)</label>
          <input
            type="text"
            name="typ"
            value={form.typ}
            onChange={handleChange}
            className="w-full border rounded px-3 py-2"
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Zaznacz granice na mapie</label>
          <MapDrawer onPolygonChange={handlePolygonChange} />
          {graniceWKT && <p className="text-xs text-green-600 mt-1">Granice zostały zaznaczone.</p>}
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Powierzchnia (ha)</label>
          <input
            type="number"
            step="0.01"
            name="powierzchnia_ha"
            value={form.powierzchnia_ha}
            onChange={handleChange}
            className="w-full border rounded px-3 py-2"
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Głębokość maks. (m)</label>
          <input
            type="number"
            step="0.1"
            name="glebokosc_max"
            value={form.glebokosc_max}
            onChange={handleChange}
            className="w-full border rounded px-3 py-2"
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Opis</label>
          <textarea
            name="opis"
            rows="3"
            value={form.opis}
            onChange={handleChange}
            className="w-full border rounded px-3 py-2"
          ></textarea>
        </div>
        <div className="flex gap-4">
          <button type="submit" disabled={loading} className="...">
            {loading ? 'Dodawanie...' : 'Dodaj łowisko'}
          </button>
          <button
            type="button"
            onClick={() => navigate('/lowiska')}
            className="bg-gray-400 text-white px-4 py-2 rounded hover:bg-gray-500"
          >
            Anuluj
          </button>
        </div>
      </form>
    </div>
  );
}