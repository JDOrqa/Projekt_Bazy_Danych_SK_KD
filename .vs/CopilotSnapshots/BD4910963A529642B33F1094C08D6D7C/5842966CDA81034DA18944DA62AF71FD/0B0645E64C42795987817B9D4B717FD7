// frontend/src/components/MapDrawer.jsx
import React, { useState, useRef } from 'react';
import { MapContainer, TileLayer, FeatureGroup, Polygon } from 'react-leaflet';
import { EditControl } from 'react-leaflet-draw';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';
import 'leaflet-draw/dist/leaflet.draw.css';

// Naprawa ikon Leaflet dla Vite (bez require)
delete L.Icon.Default.prototype._getIconUrl;
L.Icon.Default.mergeOptions({
  iconRetinaUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon-2x.png',
  iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon.png',
  shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png',
});

const MapDrawer = ({ onPolygonChange, initialPolygonWKT = null }) => {
  const [polygon, setPolygon] = useState(null);
  const featureGroupRef = useRef();

  const geoJSONToWKT = (geoJsonPolygon) => {
    if (!geoJsonPolygon || !geoJsonPolygon.geometry) return null;
    const coords = geoJsonPolygon.geometry.coordinates[0];
    let wkt = 'POLYGON((';
    coords.forEach(coord => {
      wkt += `${coord[0]} ${coord[1]}, `;
    });
    wkt = wkt.slice(0, -2);
    wkt += '))';
    return wkt;
  };

  const _onCreate = (e) => {
    const { layerType, layer } = e;
    if (layerType === 'polygon') {
      const geoJson = layer.toGeoJSON();
      const wkt = geoJSONToWKT(geoJson);
      setPolygon(geoJson);
      if (onPolygonChange) onPolygonChange(wkt);
    }
  };

  const _onEdited = (e) => {
    const layers = e.layers;
    layers.eachLayer(layer => {
      const geoJson = layer.toGeoJSON();
      const wkt = geoJSONToWKT(geoJson);
      setPolygon(geoJson);
      if (onPolygonChange) onPolygonChange(wkt);
    });
  };

  const _onDeleted = () => {
    setPolygon(null);
    if (onPolygonChange) onPolygonChange(null);
  };

  return (
    <MapContainer center={[52.0, 19.0]} zoom={6} style={{ height: '400px', width: '100%' }}>
      <TileLayer
        attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
      />
      <FeatureGroup ref={featureGroupRef}>
        <EditControl
          position="topright"
          onCreated={_onCreate}
          onEdited={_onEdited}
          onDeleted={_onDeleted}
          draw={{
            rectangle: false,
            circle: false,
            circlemarker: false,
            marker: false,
            polyline: false,
            polygon: true,
          }}
        />
      </FeatureGroup>
      {polygon && (
        <Polygon
          positions={polygon.geometry.coordinates[0].map(coord => [coord[1], coord[0]])}
        />
      )}
    </MapContainer>
  );
};

export default MapDrawer;