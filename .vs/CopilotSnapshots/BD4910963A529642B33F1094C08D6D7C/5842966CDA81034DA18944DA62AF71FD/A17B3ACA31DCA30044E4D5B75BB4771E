// frontend/src/pages/Dashboard.jsx
import { useEffect, useState } from 'react';
import { useNavigate, Link } from 'react-router-dom';
import api from '../api';
import toast from 'react-hot-toast';

export default function Dashboard() {
  const [stats, setStats] = useState({});
  const [user, setUser] = useState(null);
  const navigate = useNavigate();

  useEffect(() => {
    api.get('/dashboard/stats').then(res => setStats(res.data));
    api.get('/users/me').then(res => setUser(res.data));
  }, []);

  const handleLogout = () => {
    localStorage.removeItem('access_token');
    toast.success('Wylogowano pomyślnie');
    navigate('/login');
  };

  return (
    <div className="p-6">
      <div className="flex justify-between items-center mb-6">
        <h1 className="text-3xl font-bold">Dashboard</h1>
        <button
          onClick={handleLogout}
          className="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700"
        >
          Wyloguj się
        </button>
      </div>
      {user && <p>Witaj, {user.imie} {user.nazwisko}!</p>}
      <div className="grid grid-cols-3 gap-4 mt-6">
        <div className="bg-blue-100 p-4 rounded">Sesje: {stats.liczba_sesji}</div>
        <div className="bg-green-100 p-4 rounded">Złowione ryby: {stats.liczba_ryb}</div>
        <div className="bg-yellow-100 p-4 rounded">Ostatnia aktywność: {stats.ostatnia_aktywnosc || 'brak'}</div>
      </div>
      <div className="mt-6 flex gap-4">
        <Link to="/lowiska" className="bg-gray-700 text-white px-4 py-2 rounded">Przeglądaj łowiska</Link>
        <Link to="/profile" className="bg-gray-500 text-white px-4 py-2 rounded">Mój profil</Link>
      </div>
    </div>
  );
}