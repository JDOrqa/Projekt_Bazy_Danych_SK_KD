import { useEffect, useState } from 'react';
import api from '../api';
import toast from 'react-hot-toast';
import { useNavigate } from 'react-router-dom';

export default function Profile() {
  const [user, setUser] = useState(null);
  const navigate = useNavigate();

  useEffect(() => {
    api.get('/users/me').then(res => setUser(res.data));
  }, []);

  const handleDeleteAccount = async () => {
    if (confirm('Czy na pewno chcesz usunąć konto? (RODO – dane zostaną trwale usunięte)')) {
      await api.delete('/users/me');
      localStorage.removeItem('access_token');
      toast.success('Konto usunięte');
      navigate('/login');
    }
  };

  if (!user) return <div>Ładowanie...</div>;

  return (
    <div className="p-6">
      <h1 className="text-2xl font-bold mb-4">Mój profil</h1>
      <p>Email: {user.email}</p>
      <p>Imię: {user.imie}</p>
      <p>Nazwisko: {user.nazwisko}</p>
      <p>Status: {user.status}</p>
      <button onClick={handleDeleteAccount} className="mt-6 bg-red-600 text-white px-4 py-2 rounded">Usuń konto (RODO)</button>
    </div>
  );
}