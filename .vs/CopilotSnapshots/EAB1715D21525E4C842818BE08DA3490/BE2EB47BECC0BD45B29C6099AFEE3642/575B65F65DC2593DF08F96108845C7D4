from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, update
from sqlalchemy.sql import func  
from geoalchemy2 import WKTElement
import models
import schemas

async def get_user_by_email(db: AsyncSession, email: str):
    result = await db.execute(select(models.Uzytkownik).where(models.Uzytkownik.email == email))
    return result.scalar_one_or_none()

async def create_user(db: AsyncSession, user: schemas.UserCreate):
    hashed = models.Uzytkownik.hash_password(user.password)
    db_user = models.Uzytkownik(
        email=user.email,
        haslo_hash=hashed,
        imie=user.imie,
        nazwisko=user.nazwisko,
        zgoda_marketingowa=user.zgoda_marketingowa
    )
    db.add(db_user)
    await db.commit()
    await db.refresh(db_user)
    return db_user

async def update_user(db: AsyncSession, user_id: int, update_data: dict):
    await db.execute(update(models.Uzytkownik).where(models.Uzytkownik.id == user_id).values(**update_data))
    await db.commit()
    result = await db.execute(select(models.Uzytkownik).where(models.Uzytkownik.id == user_id))
    return result.scalar_one_or_none()

async def create_lowisko(db: AsyncSession, lowisko: schemas.LowiskoCreate, wlasciciel_id: int):
    granice_geom = None
    if lowisko.granice:
        wkt_str = lowisko.granice
        if wkt_str.startswith('SRID=4326;'):
            wkt_str = wkt_str.replace('SRID=4326;', '')
        granice_geom = WKTElement(wkt_str, srid=4326)
    
    db_lowisko = models.Lowisko(
        nazwa=lowisko.nazwa,
        typ=lowisko.typ,
        granice=granice_geom,
        powierzchnia_ha=lowisko.powierzchnia_ha,
        glebokosc_max=lowisko.glebokosc_max,
        opis=lowisko.opis,
        wlasciciel_id=wlasciciel_id
    )
    db.add(db_lowisko)
    await db.commit()
    await db.refresh(db_lowisko)
    return db_lowisko

async def delete_user(db: AsyncSession, user_id: int):
    await db.execute(update(models.Uzytkownik).where(models.Uzytkownik.id == user_id).values(deleted_at=func.now()))
    await db.commit()

async def delete_lowisko(db: AsyncSession, lowisko_id: int):
    await db.execute(update(models.Lowisko).where(models.Lowisko.id == lowisko_id).values(deleted_at=func.now()))
    await db.commit()

async def get_lowiska(db: AsyncSession, skip=0, limit=100):
result = await db.execute(select(models.Lowisko).where(models.Lowisko.deleted_at.is_(None)).offset(skip).limit(limit))
lowiska = result.scalars().all()
# Konwertuj geometrię do WKT dla każdego łowiska
for lowisko in lowiska:
    if lowisko.granice is not None:
        try:
            if hasattr(lowisko.granice, 'desc'):
                lowisko.granice = str(lowisko.granice)
        except Exception as e:
            print(f"Error converting geometry: {e}")
return lowiska

async def get_lowisko_by_id(db: AsyncSession, lowisko_id: int):
    result = await db.execute(select(models.Lowisko).where(models.Lowisko.id == lowisko_id).where(models.Lowisko.deleted_at.is_(None)))
    return result.scalar_one_or_none()

async def update_lowisko(db: AsyncSession, lowisko_id: int, lowisko: schemas.LowiskoCreate):
    granice_geom = None
    if lowisko.granice:
        wkt_str = lowisko.granice
        if wkt_str.startswith('SRID=4326;'):
            wkt_str = wkt_str.replace('SRID=4326;', '')
        granice_geom = WKTElement(wkt_str, srid=4326)
    
    update_data = {
        'nazwa': lowisko.nazwa,
        'typ': lowisko.typ,
        'granice': granice_geom,
        'powierzchnia_ha': lowisko.powierzchnia_ha,
        'glebokosc_max': lowisko.glebokosc_max,
        'opis': lowisko.opis
    }
    
    await db.execute(update(models.Lowisko).where(models.Lowisko.id == lowisko_id).values(**update_data))
    await db.commit()
    result = await db.execute(select(models.Lowisko).where(models.Lowisko.id == lowisko_id))
    return result.scalar_one_or_none()