from pydantic import BaseModel, EmailStr, Field, validator
from typing import Optional
from datetime import datetime

class UserCreate(BaseModel):
    email: EmailStr
    password: str = Field(..., min_length=4, max_length=72) 
    imie: str
    nazwisko: str
    zgoda_marketingowa: bool = False

    @validator('password')
    def validate_password_length(cls, v):
        if len(v.encode('utf-8')) > 72:
            raise ValueError('Hasło jest zbyt długie – maksymalnie 72 bajty')
        return v

class UserOut(BaseModel):
    id: int
    email: EmailStr
    imie: str
    nazwisko: str
    status: str
    created_at: datetime
    
class LowiskoCreate(BaseModel):
    nazwa: str
    typ: Optional[str] = None
    granice: Optional[str] = None  # WKT POLYGON, np. "POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))"
    powierzchnia_ha: Optional[float] = None
    glebokosc_max: Optional[float] = None
    opis: Optional[str] = None    

class Token(BaseModel):
    access_token: str
    token_type: str

class LowiskoOut(BaseModel):
    id: int
    nazwa: str
    typ: Optional[str] = None
    granice: Optional[str] = None  # oczekujemy stringa WKT
    powierzchnia_ha: Optional[float] = None
    glebokosc_max: Optional[float] = None
    opis: Optional[str] = None
    wlasciciel_id: int
    created_at: datetime
    updated_at: Optional[datetime] = None
    deleted_at: Optional[datetime] = None

    @validator('granice', pre=True, always=True)
    def convert_geometry(cls, v):
        if v is None:
            return None
        # Jeśli to obiekt WKBElement, zamień na string
        if hasattr(v, 'desc'):
            return str(v)
        return v