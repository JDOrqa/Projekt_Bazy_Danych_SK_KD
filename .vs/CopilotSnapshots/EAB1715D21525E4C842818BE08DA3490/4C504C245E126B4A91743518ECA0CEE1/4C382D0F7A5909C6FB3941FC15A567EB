import React, { useState, FormEvent, useEffect } from 'react';
import { useNavigate, useParams } from 'react-router-dom';
import { ArrowLeft } from 'lucide-react';
import axios from 'axios';
import { Card } from '../components/ui/Card';
import { Button } from '../components/ui/Button';
import { Input } from '../components/ui/Input';
import { Select } from '../components/ui/Select';
import { Textarea } from '../components/ui/Textarea';
import MapDrawer from '../components/MapDrawer';
import { motion } from 'motion/react';
import { useAuth } from '../context/AuthContext';

const API_BASE_URL = import.meta.env.VITE_API_URL || 'http://localhost:8000';

export function AddFishingGround() {
  const navigate = useNavigate();
  const { id } = useParams<{ id?: string }>();
  const { user } = useAuth();
  const isEditing = !!id;
  const [loading, setLoading] = useState(false);
  const [initialLoading, setInitialLoading] = useState(isEditing);
  const [formData, setFormData] = useState({
    nazwa: '',
    typ: 'jezioro' as const,
    powierzchnia_ha: '',
    glebokosc_max: '',
    opis: '',
    granice: ''
  });

  // Załaduj dane łowiska jeśli edytujemy
  useEffect(() => {
    if (isEditing && id) {
      const fetchGround = async () => {
        try {
          const token = localStorage.getItem('auth_token');
          const response = await axios.get(`${API_BASE_URL}/api/lowiska/${id}`, {
            headers: {
              Authorization: `Bearer ${token}`
            }
          });
          
          setFormData({
            nazwa: response.data.nazwa,
            typ: response.data.typ,
            powierzchnia_ha: response.data.powierzchnia_ha?.toString() || '',
            glebokosc_max: response.data.glebokosc_max?.toString() || '',
            opis: response.data.opis || '',
            granice: response.data.granice || ''
          });
        } catch (error: any) {
          console.error('Error fetching fishing ground:', error);
          alert('Błąd ładowania danych łowiska');
          navigate('/lowiska');
        } finally {
          setInitialLoading(false);
        }
      };

      fetchGround();
    }
  }, [id, isEditing, navigate]);

  const handleChange = (e: React.ChangeEvent<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>) => {
    setFormData(prev => ({ ...prev, [e.target.name]: e.target.value }));
  };

  const handlePolygonChange = (wkt: string | null) => {
    setFormData(prev => ({ ...prev, granice: wkt || '' }));
  };

  const handleSubmit = async (e: FormEvent) => {
    e.preventDefault();
    setLoading(true);

    try {
      const token = localStorage.getItem('auth_token');
      
      const payload = {
        nazwa: formData.nazwa,
        typ: formData.typ,
        powierzchnia_ha: formData.powierzchnia_ha ? parseFloat(formData.powierzchnia_ha) : null,
        glebokosc_max: formData.glebokosc_max ? parseFloat(formData.glebokosc_max) : null,
        opis: formData.opis,
        granice: formData.granice || null
      };

      if (isEditing && id) {
        // Edycja
        await axios.put(`${API_BASE_URL}/api/lowiska/${id}`, payload, {
          headers: {
            Authorization: `Bearer ${token}`
          }
        });
        navigate(`/lowiska/${id}`);
      } else {
        // Dodawanie
        await axios.post(`${API_BASE_URL}/api/lowiska`, payload, {
          headers: {
            Authorization: `Bearer ${token}`
          }
        });
        navigate('/lowiska');
      }
    } catch (error: any) {
      console.error('Error:', error);
      alert(error.response?.data?.detail || (isEditing ? 'Błąd edycji łowiska' : 'Błąd dodawania łowiska'));
    } finally {
      setLoading(false);
    }
  };

  const typeOptions = [
    { value: 'jezioro', label: 'Jezioro' },
    { value: 'rzeka', label: 'Rzeka' },
    { value: 'staw', label: 'Staw' },
    { value: 'zalew', label: 'Zalew' },
    { value: 'kanal', label: 'Kanał' }
  ];

  if (initialLoading) {
    return (
      <div className="space-y-6">
        <Button
          variant="outline"
          onClick={() => navigate('/lowiska')}
          className="flex items-center gap-2"
        >
          <ArrowLeft className="w-4 h-4" />
          Wróć do listy
        </Button>
        <Card className="p-12 text-center">
          <p className="text-gray-600">Ładowanie danych...</p>
        </Card>
      </div>
    );
  }

  return (
    <div className="max-w-3xl mx-auto space-y-6">
      {/* Header */}
      <motion.div
        initial={{ opacity: 0, y: -20 }}
        animate={{ opacity: 1, y: 0 }}
      >
        <Button
          variant="outline"
          onClick={() => navigate(isEditing ? `/lowiska/${id}` : '/lowiska')}
          className="mb-4 flex items-center gap-2"
        >
          <ArrowLeft className="w-4 h-4" />
          Wróć
        </Button>

        <h1 className="text-3xl font-bold text-gray-900 mb-2">
          {isEditing ? 'Edytuj łowisko' : 'Dodaj łowisko'}
        </h1>
        <p className="text-gray-600">
          {isEditing ? 'Zmień informacje o łowisku' : 'Wprowadź informacje o nowym łowisku'}
        </p>
      </motion.div>

      {/* Form */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.1 }}
      >
        <Card className="p-8">
          <form onSubmit={handleSubmit} className="space-y-6">
            <Input
              label="Nazwa łowiska"
              name="nazwa"
              placeholder="np. Jezioro Śniardwy"
              value={formData.nazwa}
              onChange={handleChange}
              required
            />

            <Select
              label="Typ łowiska"
              name="typ"
              options={typeOptions}
              value={formData.typ}
              onChange={handleChange}
              required
            />

            <div className="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <Input
                label="Powierzchnia (ha)"
                name="powierzchnia_ha"
                type="number"
                step="0.1"
                placeholder="np. 113.8"
                value={formData.powierzchnia_ha}
                onChange={handleChange}
              />

              <Input
                label="Maksymalna głębokość (m)"
                name="glebokosc_max"
                type="number"
                step="0.1"
                placeholder="np. 23"
                value={formData.glebokosc_max}
                onChange={handleChange}
              />
            </div>

            <Textarea
              label="Opis"
              name="opis"
              placeholder="Opisz łowisko, gatunki ryb, dostępność..."
              value={formData.opis}
              onChange={handleChange}
              rows={4}
            />

            {/* Map Component */}
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                Zaznacz granice na mapie
              </label>
              <MapDrawer 
                onPolygonChange={handlePolygonChange}
                initialPolygonWKT={formData.granice || null}
              />
              {formData.granice && (
                <p className="mt-2 text-sm text-green-600">
                  ✓ Granice zaznaczone na mapie
                </p>
              )}
            </div>

            {/* Actions */}
            <div className="flex items-center justify-end gap-3 pt-4">
              <Button
                type="button"
                variant="secondary"
                onClick={() => navigate(isEditing ? `/lowiska/${id}` : '/lowiska')}
              >
                Anuluj
              </Button>
              <Button
                type="submit"
                disabled={loading}
              >
                {loading ? (isEditing ? 'Aktualizowanie...' : 'Dodawanie...') : (isEditing ? 'Aktualizuj' : 'Dodaj łowisko')}
              </Button>
            </div>
          </form>
        </Card>
      </motion.div>

      {/* Info Box */}
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        transition={{ delay: 0.2 }}
      >
        <Card className="p-4 bg-blue-50 border-blue-200">
          <p className="text-sm text-blue-800">
            <strong>Wskazówka:</strong> Im dokładniejsze informacje podasz, tym łatwiej będzie Ci planować kolejne wyprawy wędkarskie.
          </p>
        </Card>
      </motion.div>
    </div>
  );
}
